# Docker Compose 环境变量配置
# 复制此文件为 .env 并填入实际值

# JWT Configuration
JWT_SECRET=change-this-in-production-use-a-strong-random-string

# LLM API Configuration
# 选项 1: 使用 OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# 选项 2: 使用自定义 LLM API (例如 Webull 内部 Claude)
LLM_API_URL=your-custom-llm-api-url
LLM_API_KEY=your-custom-llm-api-key
LLM_MODEL=claude-sonnet-4
LLM_API_KEY_HEADER=Authorization
LLM_AUTH_PREFIX=Bearer

# Feature Flags
ENABLE_WEBSITE_ANALYZER=false
