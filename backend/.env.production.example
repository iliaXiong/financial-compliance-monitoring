# Production Environment Variables for Backend
# 复制此文件为 .env.production 并填入实际值

# Server Configuration
NODE_ENV=production
PORT=3000
TZ=Asia/Shanghai

# Supabase PostgreSQL Database
DB_HOST=db.your-project.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-db-password

# Upstash Redis
REDIS_HOST=your-redis.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-redis-password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# External Services
JINA_READER_API_URL=https://r.jina.ai

# LLM API Configuration (使用 Webull 内部 Claude Sonnet 4)
LLM_API_URL=your-webull-llm-api-url
LLM_API_KEY=your-webull-llm-api-key
LLM_MODEL=claude-sonnet-4
LLM_API_KEY_HEADER=Authorization
LLM_AUTH_PREFIX=Bearer

# Performance Configuration
MAX_PARALLEL_WEBSITES=5
RETRIEVAL_TIMEOUT_MS=30000

# Feature Flags
ENABLE_WEBSITE_ANALYZER=false
DEMO_MODE=false
