# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (PostgreSQL)
# 注意：使用 pg-boss 时，数据库同时用于数据存储和任务队列
DB_HOST=localhost
DB_PORT=5432
DB_NAME=financial_compliance
DB_USER=postgres
DB_PASSWORD=postgres

# 任务队列配置
# 默认使用 pg-boss (基于 PostgreSQL)
# 如果需要使用 Redis + BullMQ，请使用 index.ts 而不是 index.pgboss.ts

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# External APIs
JINA_READER_API_URL=https://r.jina.ai

# LLM API Configuration (支持 OpenAI 和自定义端点)
# 方式1: 使用 OpenAI (默认)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# 方式2: 使用自定义 LLM 端点 (优先级高于 OpenAI 配置)
# LLM_API_URL=https://office.webullbroker.com/api/oa-ai/open/chat/completions
# LLM_API_KEY=dcb0d1c8-82c7-478f-bd9a-7c3023cac4d8
# LLM_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0
# LLM_API_KEY_HEADER=authorization
# LLM_AUTH_PREFIX=Bearer

# Task Configuration
MAX_PARALLEL_WEBSITES=5
RETRIEVAL_TIMEOUT_MS=30000

# Feature Flags
ENABLE_WEBSITE_ANALYZER=false
